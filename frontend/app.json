{
  "expo": {
    "name": "PortPassLH",
    "slug": "portpasslh",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "portpasslh",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.portpasslh.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Alertes de proximité des ponts et écluses",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Alertes de proximité des ponts et écluses",
        "UIBackgroundModes": ["location"]
      }
    },
    "android": {
      "package": "com.portpasslh.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#050A11"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "VIBRATE",
        "POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Alertes de proximité des ponts et écluses"
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#2563EB"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#050A11"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
